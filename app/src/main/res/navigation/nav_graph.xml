<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/languageSelectionFragment">

    <fragment
        android:id="@+id/languageSelectionFragment"
        android:name="com.dev.scout_new_api.ui.LanguageSelectionFragment"
        android:label="Language Selection"
        tools:layout="@layout/fragment_language_selection">
        <action
            android:id="@+id/action_languageSelectionFragment_to_welcomeFragment"
            app:destination="@id/welcomeFragment" />
    </fragment>

    <fragment
        android:id="@+id/welcomeFragment"
        android:name="com.dev.scout_new_api.ui.WelcomeFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_welcome">
        <action
            android:id="@+id/action_welcomeFragment_to_termsOfServiceFragment"
            app:destination="@id/termsOfServiceFragment" />
        <action
            android:id="@+id/action_welcomeFragment_to_enterEmailFragment"
            app:destination="@id/enterEmailFragment" />
    </fragment>

    <fragment
        android:id="@+id/termsOfServiceFragment"
        android:name="com.dev.scout_new_api.TermsOfServiceFragment"
        android:label="Terms of Service"
        tools:layout="@layout/fragment_terms_of_service" />

    <fragment
        android:id="@+id/enterEmailFragment"
        android:name="com.dev.scout_new_api.ui.EnterEmailFragment"
        android:label="Enter Email"
        tools:layout="@layout/fragment_enter_email">
        <action
            android:id="@+id/action_enterEmailFragment_to_verifyEmailFragment"
            app:destination="@id/verifyEmailFragment" />
    </fragment>

    <fragment
        android:id="@+id/verifyEmailFragment"
        android:name="com.dev.scout_new_api.ui.VerifyEmailFragment"
        android:label="Verify Email"
        tools:layout="@layout/fragment_verify_email" />

</navigation>
